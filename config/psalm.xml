<?xml version="1.0"?>
<psalm
    errorLevel="8"
    resolveFromConfigFile="true"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config ../vendor/vimeo/psalm/config.xsd"
    findUnusedBaselineEntry="true"
    findUnusedCode="true"
    phpVersion="8.3.0"
    cacheDirectory="../cache/psalm"
>
    <projectFiles>
        <directory name="../src"/>
        <directory name="../tests"/>
        <file name="../bootstrap-alias.php"/>
        <ignoreFiles allowMissingFiles="true">
            <directory name="../vendor"/>
        </ignoreFiles>
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin"/>
    </plugins>

    <!--
        findUnusedCode noise we accept:
        - UnusedConstructor: static-only / factory helpers with private __construct and no literal "new Class" in-tree.
        - PossiblyUnusedMethod on CacheClient: PECL-shaped interface; call sites use concrete clients.
        - PossiblyUnusedMethod in tests: PHPUnit #[DataProvider] static providers are not always linked by Psalm.
    -->
    <issueHandlers>
        <UnusedConstructor errorLevel="suppress"/>
        <PossiblyUnusedMethod>
            <errorLevel type="suppress">
                <file name="../src/PureCache/CacheClient.php"/>
                <directory name="../tests"/>
            </errorLevel>
        </PossiblyUnusedMethod>
        <UnusedProperty>
            <errorLevel type="suppress">
                <file name="../src/PureCache/Internal/KetamaContinuum.php"/>
            </errorLevel>
        </UnusedProperty>
    </issueHandlers>
</psalm>
