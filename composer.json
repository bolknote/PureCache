{
    "name": "purecache/cache",
    "description": "Pure PHP PECL-compatible Memcached API with memcached (meta protocol), Redis, and Apache Ignite backends",
    "type": "library",
    "license": "MIT",
    "config": {
        "process-timeout": 0,
        "platform": {
            "php": "8.3.31"
        },
        "allow-plugins": {
            "infection/extension-installer": true
        }
    },
    "require": {
        "php": "~8.3.0",
        "ext-json": "*"
    },
    "suggest": {
        "ext-igbinary": "For Memcached::SERIALIZER_IGBINARY",
        "ext-msgpack": "For Memcached::SERIALIZER_MSGPACK",
        "ext-zlib": "For zlib compression",
        "ext-zstd": "For ZSTD compression",
        "ext-fastlz": "For FastLZ compression (COMPRESSION_TYPE_FASTLZ)"
    },
    "autoload": {
        "psr-4": {
            "PureCache\\": "src/PureCache/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PureCache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php scripts/run-phpunit.php --configuration=config/phpunit.xml",
        "test:no-opt-ext": "@php scripts/run-phpunit-no-opt-ext.php",
        "test:integration": "@php scripts/run-memcached-tests.php",
        "test:parity": "@php scripts/run-memcached-tests.php tests/Parity",
        "test:contract": [
            "@php scripts/run-memcached-tests.php --filter BackendContract",
            "@php scripts/run-redis-tests.php --filter BackendContract",
            "@php scripts/run-ignite-tests.php --filter BackendContract"
        ],
        "test:redis": "@php scripts/run-redis-tests.php",
        "test:ignite": "@php scripts/run-ignite-tests.php",
        "test:integration:all": [
            "@test:integration",
            "@test:redis",
            "@test:ignite"
        ],
        "test:coverage": [
            "@php vendor/bin/phpunit --configuration=config/phpunit-coverage.xml --coverage-text --colors=never",
            "@php scripts/assert-min-line-coverage.php cache/coverage.xml 90"
        ],
        "test:mutation": "@php scripts/run-infection.php",
        "phpstan": "phpstan analyse --memory-limit=512M --configuration=config/phpstan.neon",
        "psalm": "psalm --config=config/psalm.xml --memory-limit=512M --no-progress",
        "psalm:level1": "psalm --config=config/psalm-level1.xml --memory-limit=512M --no-progress",
        "cs-fix": "php-cs-fixer fix --config=config/php-cs-fixer.dist.php",
        "cs-check": "php-cs-fixer fix --dry-run --diff --config=config/php-cs-fixer.dist.php",
        "rector": "rector process --config=config/rector.php",
        "rector-check": "rector process --dry-run --no-progress-bar --config=config/rector.php",
        "check": [
            "@phpstan",
            "@psalm",
            "@psalm:level1",
            "@cs-check",
            "@rector-check",
            "@test",
            "@test:no-opt-ext"
        ],
        "check:full": [
            "@check",
            "@test:coverage",
            "@test:integration:all",
            "@test:contract",
            "@test:mutation"
        ]
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.95",
        "rector/rector": "^2.4",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "vimeo/psalm": "^6.16",
        "psalm/plugin-phpunit": "^0.19",
        "infection/infection": "^0.31"
    }
}
