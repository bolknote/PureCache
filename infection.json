{
    "$schema": "vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": ["src/PureCache"]
    },
    "logs": {
        "text": "cache/infection.log",
        "summary": "cache/infection-summary.log"
    },
    "tmpDir": "cache/infection/tmp",
    "phpUnit": {
        "configDir": "config",
        "customPath": "config/phpunit-coverage.xml"
    },
    "mutators": {
        "@default": true
    },
    "minMsi": 90,
    "minCoveredMsi": 95,
    "ignoreMsiWithNoMutations": true,
    "timeout": 10,
    "threads": 4
}
